---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdminPanel from '../components/AdminPanel.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = '记录学习、分享技术、复盘项目的个人博客', wide = false } = Astro.props;
const mainClass = wide
  ? 'flex-1 w-full max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-10'
  : 'flex-1 w-full max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-10';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | 个人博客</title>
  </head>
  <body class="min-h-screen flex flex-col text-text">
    <Header />
    <main class={mainClass}>
      <slot />
    </main>
    <Footer />
    <AdminPanel />

    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 p-2.5 bg-text text-bg-card border border-border rounded-full shadow-lg opacity-0 pointer-events-none transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary z-50"
      title="回到顶部"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <script is:inline>
      const btn = document.getElementById('back-to-top');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          btn?.classList.remove('opacity-0', 'pointer-events-none');
          btn?.classList.add('opacity-100');
        } else {
          btn?.classList.add('opacity-0', 'pointer-events-none');
          btn?.classList.remove('opacity-100');
        }
      });
      btn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      const copyText = async (text) => {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }

        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'fixed';
        textarea.style.top = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        textarea.remove();
      };

      const escapeCodeHtml = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');

      const fallbackHighlight = (code) => {
        if (!code.textContent?.trim() || code.classList.contains('is-fallback-highlighted')) return;

        const tokens = [];
        const stash = (className) => (match) => {
          const placeholder = String.fromCharCode(0xe000 + tokens.length);
          tokens.push(`<span class="${className}">${match}</span>`);
          return placeholder;
        };

        let html = escapeCodeHtml(code.textContent)
          .replace(/(&quot;.*?&quot;|&#39;.*?&#39;|".*?"|'.*?'|`.*?`|“.*?”|‘.*?’)/g, stash('hljs-string'))
          .replace(/(^|\s)(#.*$|\/\/.*$)/gm, (_, prefix, comment) => `${prefix}${stash('hljs-comment')(comment)}`)
          .replace(/\b(import|from|class|def|return|if|elif|else|for|while|try|except|with|as|in|is|not|and|or|None|True|False|const|let|var|function|new|await|async|public|private|protected|static|void|int|long|float|double|boolean|String|interface|extends|implements|package)\b/g, '<span class="hljs-keyword">$1</span>')
          .replace(/\b(console|print|len|range|dict|list|set|OpenAI|JSON|Promise|fetch|Math|Date)\b/g, '<span class="hljs-built_in">$1</span>')
          .replace(/\b(\d+(?:\.\d+)?)\b/g, '<span class="hljs-number">$1</span>');

        tokens.forEach((token, index) => {
          html = html.replaceAll(String.fromCharCode(0xe000 + index), token);
        });

        code.innerHTML = html;
        code.classList.add('hljs', 'is-fallback-highlighted');
      };

      const highlightCode = (code) => {
        if (
          !code ||
          code.classList.contains('hljs') ||
          code.querySelector('[style*="--shiki-light"]')
        ) {
          return;
        }

        try {
          if (typeof hljs !== 'undefined') {
            const languageClass = [...code.classList].find((className) => className.startsWith('language-'));
            if (languageClass) {
              hljs.highlightElement(code);
            } else {
              const result = hljs.highlightAuto(code.textContent || '');
              code.innerHTML = result.value;
              code.classList.add('hljs');
              if (result.language) code.classList.add(`language-${result.language}`);
            }
            if (!code.querySelector('span[class*="hljs-"]')) fallbackHighlight(code);
          } else {
            fallbackHighlight(code);
          }
        } catch {
          fallbackHighlight(code);
        }
      };

      window.enhanceCodeBlocks = (root = document) => {
        root.querySelectorAll('.prose pre').forEach((pre) => {
          const code = pre.querySelector('code');
          highlightCode(code);

          if (pre.parentElement?.classList.contains('code-block')) return;

          const wrapper = document.createElement('div');
          wrapper.className = 'code-block';
          pre.parentNode?.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          const copyBtn = document.createElement('button');
          copyBtn.type = 'button';
          copyBtn.className = 'code-copy-btn';
          copyBtn.textContent = '复制';
          copyBtn.setAttribute('aria-label', '复制代码');
          wrapper.appendChild(copyBtn);

          copyBtn.addEventListener('click', async () => {
            try {
              await copyText(pre.innerText.trimEnd());
              copyBtn.textContent = '已复制';
              copyBtn.classList.add('is-copied');
              window.setTimeout(() => {
                copyBtn.textContent = '复制';
                copyBtn.classList.remove('is-copied');
              }, 1500);
            } catch {
              copyBtn.textContent = '失败';
              window.setTimeout(() => {
                copyBtn.textContent = '复制';
              }, 1500);
            }
          });
        });
      };

      window.enhanceCodeBlocks();
      window.addEventListener('load', () => window.enhanceCodeBlocks());
    </script>
  </body>
</html>

---
interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
}

const { title, date, description, tags, slug } = Astro.props;

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<article class="py-6 border-b border-border last:border-b-0">
  <a href={`/posts/${slug}`} class="group block">
    <h3 class="text-lg font-semibold group-hover:text-primary transition-colors">
      {title}
    </h3>
    {description && (
      <p class="mt-1 text-text-secondary text-sm line-clamp-2">{description}</p>
    )}
    <div class="mt-3 flex items-center gap-3 text-xs text-text-secondary">
      <time datetime={date.toISOString()}>{dateStr}</time>
      {tags.length > 0 && (
        <div class="flex gap-1.5">
          {tags.map((tag) => (
            <span class="px-2 py-0.5 bg-gray-100 rounded-full">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

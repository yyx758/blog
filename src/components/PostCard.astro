---
interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
  readTime?: number;
}

const { title, date, description, tags, slug, readTime } = Astro.props;

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<article class="group rounded-lg border border-border bg-bg-card/75 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-border-strong hover:shadow-md">
  <a href={`/posts/${slug}`} class="block p-5 sm:p-6">
    <div class="flex flex-wrap items-center gap-2 text-xs text-text-secondary">
      <time datetime={date.toISOString()}>{dateStr}</time>
      {readTime && <span>· {readTime} 分钟阅读</span>}
    </div>

    <h3 class="mt-3 text-lg font-semibold tracking-tight text-text transition-colors group-hover:text-primary">
      {title}
    </h3>

    <p class="mt-2 min-h-[2.75rem] text-sm leading-6 text-text-secondary line-clamp-2">
      {description || '这篇文章暂未填写摘要，点击进入阅读全文。'}
    </p>

    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 4).map((tag) => (
          <span class="rounded-full border border-border bg-bg-muted px-2.5 py-1 text-xs text-text-secondary transition-colors group-hover:border-primary/25 group-hover:text-text">
            {tag}
          </span>
        ))}
      </div>
      <span class="text-xs font-medium text-primary transition-transform group-hover:translate-x-0.5">
        阅读全文 -&gt;
      </span>
    </div>
  </a>
</article>

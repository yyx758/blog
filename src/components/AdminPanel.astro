---
---

<!-- 管理员按钮 -->
<button
  id="admin-toggle"
  class="fixed bottom-6 left-4 sm:left-6 inline-flex items-center gap-2 px-3 py-2 bg-bg-card/85 border border-border text-text-secondary rounded-full shadow-sm backdrop-blur hover:-translate-y-0.5 hover:shadow-md hover:border-border-strong hover:text-text transition-all z-40 text-xs font-medium"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
    <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
    <circle cx="12" cy="12" r="3"/>
  </svg>
  管理文章
</button>

<!-- 管理面板 -->
<div
  id="admin-panel"
  class="fixed inset-y-0 right-0 w-full sm:w-[480px] bg-bg-card border-l border-border shadow-2xl transform translate-x-full transition-transform duration-300 z-50 flex flex-col"
>
  <!-- 面板头部 -->
  <div class="flex items-center justify-between px-5 py-4 border-b border-border">
    <h2 class="text-lg font-semibold">文章管理</h2>
    <button id="admin-close" class="p-1.5 text-text-secondary hover:text-primary transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- 登录视图 -->
  <div id="admin-login" class="flex-1 flex flex-col items-center justify-center px-8 text-center">
    <div class="mb-6 text-text-secondary">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 mx-auto mb-4 opacity-40">
        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
        <polyline points="10 17 15 12 10 7"/>
        <line x1="15" y1="12" x2="3" y2="12"/>
      </svg>
      <p class="text-sm">使用 GitHub 账号登录后<br>即可管理文章</p>
    </div>
    <button
      id="github-login"
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#24292f] text-white text-sm font-medium rounded-lg hover:bg-[#32383f] transition-colors"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
      GitHub 登录
    </button>
  </div>

  <!-- 文章列表视图 -->
  <div id="admin-list" class="flex-1 flex-col hidden">
    <div class="px-5 py-3 border-b border-border flex items-center justify-between">
      <span id="post-count" class="text-sm text-text-secondary">0 篇文章</span>
      <div class="flex items-center gap-2">
        <label
          class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-border text-text-secondary text-xs font-medium rounded-lg hover:bg-bg transition-colors cursor-pointer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          上传文件
          <input id="file-upload" type="file" accept=".md,.mdx" class="hidden" />
        </label>
        <button
          id="new-post-btn"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary text-white text-xs font-medium rounded-lg hover:bg-primary-light transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          新建文章
        </button>
      </div>
    </div>
    <div id="posts-list" class="flex-1 overflow-y-auto"></div>
  </div>

  <!-- 加载状态 -->
  <div id="admin-loading" class="absolute inset-0 flex items-center justify-center bg-bg-card/80 hidden z-10">
    <div class="text-sm text-text-secondary">加载中...</div>
  </div>
</div>

<!-- 全屏编辑器 -->
<div id="admin-editor" class="fixed inset-0 bg-bg z-50 hidden flex-col">
  <!-- 编辑器顶栏 -->
  <div class="flex items-center justify-between px-4 py-3 border-b border-border bg-bg-card flex-shrink-0">
    <div class="flex items-center gap-3">
      <button id="editor-back" class="p-1.5 text-text-secondary hover:text-primary transition-colors" title="返回列表">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <span id="editor-title" class="text-sm font-medium">新建文章</span>
    </div>
    <div class="flex items-center gap-2">
      <!-- 预览切换 -->
      <div class="flex items-center bg-bg rounded-lg border border-border p-0.5">
        <button id="tab-edit" class="px-3 py-1 text-xs font-medium rounded-md bg-primary text-white transition-colors">编辑</button>
        <button id="tab-preview" class="px-3 py-1 text-xs font-medium rounded-md text-text-secondary hover:text-text transition-colors">预览</button>
        <button id="tab-split" class="px-3 py-1 text-xs font-medium rounded-md text-text-secondary hover:text-text transition-colors">分屏</button>
      </div>
      <button id="editor-delete" class="p-1.5 text-red-400 hover:text-red-600 transition-colors hidden" title="删除文章">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
          <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
        </svg>
      </button>
      <button
        id="editor-save"
        class="px-4 py-1.5 bg-primary text-white text-xs font-medium rounded-lg hover:bg-primary-light transition-colors"
      >
        发布
      </button>
    </div>
  </div>

  <!-- 元信息区 -->
  <div class="px-6 py-4 border-b border-border bg-bg-card flex-shrink-0">
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
      <div class="sm:col-span-2">
        <input id="edit-title" type="text" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors" placeholder="文章标题" />
      </div>
      <div>
        <input id="edit-date" type="date" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors" />
      </div>
      <div>
        <input id="edit-tags" type="text" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors" placeholder="标签（逗号分隔）" />
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-3 mt-3">
      <div class="sm:col-span-3">
        <input id="edit-desc" type="text" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors" placeholder="一句话描述" />
      </div>
      <div class="flex items-center gap-2">
        <input id="edit-draft" type="checkbox" class="w-4 h-4 rounded border-border text-primary focus:ring-primary" />
        <label for="edit-draft" class="text-sm text-text-secondary">草稿</label>
      </div>
    </div>
  </div>

  <!-- Markdown 工具栏 -->
  <div id="md-toolbar" class="px-4 py-1.5 border-b border-border bg-bg-card flex items-center gap-0.5 flex-shrink-0 flex-wrap">
    <button data-md="h1" class="toolbar-btn px-2 py-1 text-xs font-bold rounded hover:bg-bg transition-colors" title="标题1 (Ctrl+1)">H1</button>
    <button data-md="h2" class="toolbar-btn px-2 py-1 text-xs font-bold rounded hover:bg-bg transition-colors" title="标题2 (Ctrl+2)">H2</button>
    <button data-md="h3" class="toolbar-btn px-2 py-1 text-xs font-bold rounded hover:bg-bg transition-colors" title="标题3 (Ctrl+3)">H3</button>
    <div class="w-px h-4 bg-border mx-1"></div>
    <button data-md="bold" class="toolbar-btn px-2 py-1 text-xs font-bold rounded hover:bg-bg transition-colors" title="加粗 (Ctrl+B)">B</button>
    <button data-md="italic" class="toolbar-btn px-2 py-1 text-xs italic rounded hover:bg-bg transition-colors" title="斜体 (Ctrl+I)">I</button>
    <button data-md="strikethrough" class="toolbar-btn px-2 py-1 text-xs rounded hover:bg-bg transition-colors line-through" title="删除线 (Ctrl+Shift+X)">S</button>
    <button data-md="code" class="toolbar-btn px-2 py-1 text-xs font-mono rounded hover:bg-bg transition-colors" title="行内代码 (Ctrl+Shift+C)">&lt;/&gt;</button>
    <div class="w-px h-4 bg-border mx-1"></div>
    <button data-md="link" class="toolbar-btn px-2 py-1 text-xs rounded hover:bg-bg transition-colors" title="链接 (Ctrl+K)">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    </button>
    <button data-md="image" class="toolbar-btn px-2 py-1 text-xs rounded hover:bg-bg transition-colors" title="图片 (Ctrl+Shift+I)">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
    </button>
    <button data-md="codeblock" class="toolbar-btn px-2 py-1 text-xs font-mono rounded hover:bg-bg transition-colors" title="代码块 (Ctrl+Shift+K)">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    </button>
    <div class="w-px h-4 bg-border mx-1"></div>
    <button data-md="ul" class="toolbar-btn px-2 py-1 text-xs rounded hover:bg-bg transition-colors" title="无序列表 (Ctrl+Shift+U)">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><line x1="9" y1="6" x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/><circle cx="4" cy="6" r="1" fill="currentColor"/><circle cx="4" cy="12" r="1" fill="currentColor"/><circle cx="4" cy="18" r="1" fill="currentColor"/></svg>
    </button>
    <button data-md="ol" class="toolbar-btn px-2 py-1 text-xs rounded hover:bg-bg transition-colors" title="有序列表 (Ctrl+Shift+O)">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/><text x="2" y="8" font-size="7" fill="currentColor" font-family="monospace">1</text><text x="2" y="14" font-size="7" fill="currentColor" font-family="monospace">2</text><text x="2" y="20" font-size="7" fill="currentColor" font-family="monospace">3</text></svg>
    </button>
    <button data-md="task" class="toolbar-btn px-2 py-1 text-xs rounded hover:bg-bg transition-colors" title="任务列表">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><rect x="3" y="5" width="6" height="6" rx="1"/><path d="m5 8 1.5 1.5L9 6"/><line x1="13" y1="8" x2="21" y2="8"/><rect x="3" y="14" width="6" height="6" rx="1"/><line x1="13" y1="17" x2="21" y2="17"/></svg>
    </button>
    <div class="w-px h-4 bg-border mx-1"></div>
    <button data-md="quote" class="toolbar-btn px-2 py-1 text-xs rounded hover:bg-bg transition-colors" title="引用 (Ctrl+Shift+.)">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3z"/></svg>
    </button>
    <button data-md="hr" class="toolbar-btn px-2 py-1 text-xs rounded hover:bg-bg transition-colors" title="分割线">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><line x1="2" y1="12" x2="22" y2="12"/></svg>
    </button>
    <button data-md="table" class="toolbar-btn px-2 py-1 text-xs rounded hover:bg-bg transition-colors" title="表格">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>
    </button>
  </div>

  <!-- 编辑/预览主体 -->
  <div class="flex-1 flex overflow-hidden">
    <div id="editor-pane" class="flex-1 flex flex-col overflow-hidden">
      <textarea
        id="edit-body"
        class="flex-1 w-full px-6 py-4 bg-bg text-sm font-mono focus:outline-none resize-none leading-relaxed"
        placeholder="在此编写 Markdown 内容..."
        spellcheck="false"
      ></textarea>
    </div>
    <div id="preview-pane" class="flex-1 overflow-y-auto px-8 py-6 border-l border-border hidden">
      <div id="preview-content" class="prose max-w-none text-text"></div>
    </div>
  </div>
</div>

<!-- 上传表单弹窗 -->
<div id="upload-modal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/40">
  <div class="bg-bg-card border border-border rounded-xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden">
    <div class="flex items-center justify-between px-5 py-4 border-b border-border">
      <h3 class="text-base font-semibold">发布文章</h3>
      <button id="upload-modal-close" class="p-1 text-text-secondary hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="px-5 py-4 space-y-4">
      <div>
        <label class="block text-xs text-text-secondary mb-1">文件名</label>
        <input id="upload-filename" type="text" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors" placeholder="my-post.mdx" />
      </div>
      <div>
        <label class="block text-xs text-text-secondary mb-1">标题</label>
        <input id="upload-title" type="text" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors" placeholder="文章标题" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-text-secondary mb-1">发布日期</label>
          <input id="upload-date" type="date" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-secondary mb-1">标签</label>
          <input id="upload-tags" type="text" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors" placeholder="逗号分隔" />
        </div>
      </div>
      <div>
        <label class="block text-xs text-text-secondary mb-1">描述</label>
        <input id="upload-desc" type="text" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors" placeholder="一句话描述" />
      </div>
      <div class="flex items-center gap-2">
        <input id="upload-draft" type="checkbox" class="w-4 h-4 rounded border-border text-primary focus:ring-primary" />
        <label for="upload-draft" class="text-sm text-text-secondary">设为草稿</label>
      </div>
    </div>
    <div class="flex items-center justify-end gap-2 px-5 py-3 border-t border-border bg-bg-card">
      <button id="upload-cancel" class="px-4 py-2 text-sm text-text-secondary hover:text-text transition-colors">取消</button>
      <button id="upload-confirm" class="px-5 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary-light transition-colors">发布</button>
    </div>
  </div>
</div>

<!-- 遮罩层 -->
<div id="admin-overlay" class="fixed inset-0 bg-black/20 z-40 hidden transition-opacity"></div>

<script is:inline src="https://cdn.jsdelivr.net/npm/marked@15/marked.min.js"></script>
<script is:inline>
(function() {
  let token = localStorage.getItem('gh_token');
  let posts = [];
  let currentPost = null;

  const panel = document.getElementById('admin-panel');
  const overlay = document.getElementById('admin-overlay');
  const loginView = document.getElementById('admin-login');
  const listView = document.getElementById('admin-list');
  const editorView = document.getElementById('admin-editor');
  const loading = document.getElementById('admin-loading');

  const tabEdit = document.getElementById('tab-edit');
  const tabPreview = document.getElementById('tab-preview');
  const tabSplit = document.getElementById('tab-split');
  const editorPane = document.getElementById('editor-pane');
  const previewPane = document.getElementById('preview-pane');
  const previewContent = document.getElementById('preview-content');
  const editBody = document.getElementById('edit-body');
  const editorTitle = document.getElementById('editor-title');

  let currentTab = 'edit';

  function showView(view) {
    loginView.classList.add('hidden');
    listView.classList.add('hidden');
    editorView.classList.add('hidden');
    editorView.classList.remove('flex');
    if (view === editorView) {
      view.classList.remove('hidden');
      view.classList.add('flex');
    } else {
      view.classList.remove('hidden');
    }
  }

  function showLoading(show) {
    loading.classList.toggle('hidden', !show);
  }

  // ==================== Tab 切换 ====================

  function setTab(tab) {
    currentTab = tab;
    tabEdit.className = 'px-3 py-1 text-xs font-medium rounded-md transition-colors ' + (tab === 'edit' ? 'bg-primary text-white' : 'text-text-secondary hover:text-text');
    tabPreview.className = 'px-3 py-1 text-xs font-medium rounded-md transition-colors ' + (tab === 'preview' ? 'bg-primary text-white' : 'text-text-secondary hover:text-text');
    tabSplit.className = 'px-3 py-1 text-xs font-medium rounded-md transition-colors ' + (tab === 'split' ? 'bg-primary text-white' : 'text-text-secondary hover:text-text');

    editorPane.classList.remove('hidden', 'w-1/2');
    editorPane.classList.add('flex-1');
    previewPane.classList.add('hidden');
    previewPane.classList.remove('w-1/2');

    if (tab === 'preview') {
      editorPane.classList.add('hidden');
      previewPane.classList.remove('hidden');
      renderPreview();
    } else if (tab === 'split') {
      editorPane.classList.remove('flex-1');
      editorPane.classList.add('w-1/2');
      previewPane.classList.remove('hidden');
      previewPane.classList.add('w-1/2');
      renderPreview();
    }
  }

  function resetTabLayout() {
    editorPane.classList.remove('hidden', 'w-1/2');
    editorPane.classList.add('flex-1');
    previewPane.classList.add('hidden');
    previewPane.classList.remove('w-1/2');
    setTab('edit');
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function sanitizeHtml(html) {
    const template = document.createElement('template');
    template.innerHTML = html;
    template.content.querySelectorAll('script, iframe, object, embed, link, style').forEach((el) => el.remove());
    template.content.querySelectorAll('*').forEach((el) => {
      [...el.attributes].forEach((attr) => {
        const name = attr.name.toLowerCase();
        const value = attr.value.trim().toLowerCase();
        if (
          name.startsWith('on') ||
          name === 'srcdoc' ||
          ((name === 'href' || name === 'src') && value.startsWith('javascript:'))
        ) {
          el.removeAttribute(attr.name);
        }
      });
    });
    return template.innerHTML;
  }

  async function getErrorMessage(res, fallback) {
    try {
      const data = await res.json();
      return data?.error || data?.message || fallback;
    } catch {
      return fallback;
    }
  }

  function makeSlug(title) {
    const slug = String(title || '')
      .toLowerCase()
      .replace(/[^a-z0-9一-鿿]+/g, '-')
      .replace(/^-|-$/g, '');
    return slug || `post-${Date.now()}`;
  }

  function renderPreview() {
    const md = editBody.value;
    if (typeof marked !== 'undefined') {
      previewContent.innerHTML = sanitizeHtml(marked.parse(md));
    } else {
      previewContent.textContent = md;
    }
  }

  tabEdit.addEventListener('click', () => setTab('edit'));
  tabPreview.addEventListener('click', () => setTab('preview'));
  tabSplit.addEventListener('click', () => setTab('split'));
  editBody.addEventListener('input', () => {
    if (currentTab === 'preview') renderPreview();
    if (currentTab === 'split') renderPreview();
  });

  // ==================== Markdown 工具栏 & 快捷键 ====================

  function insertAtCursor(before, after, placeholder) {
    const start = editBody.selectionStart;
    const end = editBody.selectionEnd;
    const sel = editBody.value.substring(start, end);
    const text = sel || placeholder || '';
    const replacement = before + text + (after || '');
    editBody.setRangeText(replacement, start, end, 'select');
    editBody.focus();
    const newCursorPos = start + before.length + text.length;
    editBody.setSelectionRange(
      sel ? start + replacement.length : start + before.length,
      sel ? start + replacement.length : newCursorPos
    );
    editBody.dispatchEvent(new Event('input'));
  }

  function wrapLines(prefix) {
    const start = editBody.selectionStart;
    const end = editBody.selectionEnd;
    const val = editBody.value;
    const lineStart = val.lastIndexOf('\n', start - 1) + 1;
    const lineEnd = val.indexOf('\n', end);
    const actualEnd = lineEnd === -1 ? val.length : lineEnd;
    const selectedLines = val.substring(lineStart, actualEnd);
    const newLines = selectedLines.split('\n').map(line => prefix + line).join('\n');
    editBody.setRangeText(newLines, lineStart, actualEnd, 'select');
    editBody.focus();
    editBody.dispatchEvent(new Event('input'));
  }

  function toggleLine(prefix) {
    const start = editBody.selectionStart;
    const val = editBody.value;
    const lineStart = val.lastIndexOf('\n', start - 1) + 1;
    const lineEnd = val.indexOf('\n', start);
    const line = val.substring(lineStart, lineEnd === -1 ? val.length : lineEnd);
    if (line.startsWith(prefix)) {
      editBody.setRangeText(line.substring(prefix.length), lineStart, lineEnd === -1 ? val.length : lineEnd, 'select');
    } else {
      editBody.setRangeText(prefix + line, lineStart, lineEnd === -1 ? val.length : lineEnd, 'select');
    }
    editBody.focus();
    editBody.dispatchEvent(new Event('input'));
  }

  const mdActions = {
    h1: () => toggleLine('# '),
    h2: () => toggleLine('## '),
    h3: () => toggleLine('### '),
    bold: () => insertAtCursor('**', '**', '粗体文字'),
    italic: () => insertAtCursor('*', '*', '斜体文字'),
    strikethrough: () => insertAtCursor('~~', '~~', '删除线文字'),
    code: () => insertAtCursor('`', '`', '代码'),
    link: () => insertAtCursor('[', '](https://)', '链接文字'),
    image: () => insertAtCursor('![', '](https://)', '图片描述'),
    codeblock: () => insertAtCursor('```\n', '\n```', ''),
    ul: () => wrapLines('- '),
    ol: () => {
      const start = editBody.selectionStart;
      const end = editBody.selectionEnd;
      const val = editBody.value;
      const lineStart = val.lastIndexOf('\n', start - 1) + 1;
      const lineEnd = val.indexOf('\n', end);
      const actualEnd = lineEnd === -1 ? val.length : lineEnd;
      const selectedLines = val.substring(lineStart, actualEnd);
      const newLines = selectedLines.split('\n').map((line, i) => `${i + 1}. ${line}`).join('\n');
      editBody.setRangeText(newLines, lineStart, actualEnd, 'select');
      editBody.focus();
      editBody.dispatchEvent(new Event('input'));
    },
    task: () => wrapLines('- [ ] '),
    quote: () => wrapLines('> '),
    hr: () => insertAtCursor('\n---\n', '', ''),
    table: () => insertAtCursor('| 列1 | 列2 | 列3 |\n| --- | --- | --- |\n| ', ' |  |  |\n|  |  |  |', ''),
  };

  document.querySelectorAll('[data-md]').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = mdActions[btn.dataset.md];
      if (action) action();
    });
  });

  // ==================== 键盘快捷键 ====================

  editBody.addEventListener('keydown', (e) => {
    // Ctrl+Z / Ctrl+Y — 浏览器原生处理，不做拦截

    // Tab 缩进
    if (e.key === 'Tab') {
      e.preventDefault();
      if (e.shiftKey) {
        const start = editBody.selectionStart;
        const val = editBody.value;
        const lineStart = val.lastIndexOf('\n', start - 1) + 1;
        const line = val.substring(lineStart);
        if (line.startsWith('  ')) {
          editBody.setRangeText(line.substring(2), lineStart, lineStart + line.length, 'select');
        } else if (line.startsWith('\t')) {
          editBody.setRangeText(line.substring(1), lineStart, lineStart + line.length, 'select');
        }
      } else {
        const start = editBody.selectionStart;
        const end = editBody.selectionEnd;
        if (start === end) {
          editBody.setRangeText('  ', start, end, 'end');
        } else {
          const val = editBody.value;
          const lineStart = val.lastIndexOf('\n', start - 1) + 1;
          const lineEnd = val.indexOf('\n', end);
          const actualEnd = lineEnd === -1 ? val.length : lineEnd;
          const selected = val.substring(lineStart, actualEnd);
          const indented = selected.split('\n').map(l => '  ' + l).join('\n');
          editBody.setRangeText(indented, lineStart, actualEnd, 'select');
        }
      }
      editBody.dispatchEvent(new Event('input'));
      return;
    }

    const ctrl = e.ctrlKey || e.metaKey;

    // 只在按下 Ctrl 时处理快捷键，避免拦截 Ctrl+Z/Y
    if (ctrl) {
      if (e.key === 'b') { e.preventDefault(); mdActions.bold(); }
      else if (e.key === 'i') { e.preventDefault(); mdActions.italic(); }
      else if (e.key === 'k') { e.preventDefault(); mdActions.link(); }
      else if (e.shiftKey && e.key === 'C') { e.preventDefault(); mdActions.code(); }
      else if (e.shiftKey && e.key === 'K') { e.preventDefault(); mdActions.codeblock(); }
      else if (e.shiftKey && e.key === 'X') { e.preventDefault(); mdActions.strikethrough(); }
      else if (e.shiftKey && e.key === 'U') { e.preventDefault(); mdActions.ul(); }
      else if (e.shiftKey && e.key === 'O') { e.preventDefault(); mdActions.ol(); }
      else if (e.shiftKey && e.key === 'I') { e.preventDefault(); mdActions.image(); }
      else if (e.key === '1') { e.preventDefault(); mdActions.h1(); }
      else if (e.key === '2') { e.preventDefault(); mdActions.h2(); }
      else if (e.key === '3') { e.preventDefault(); mdActions.h3(); }
    }
  });

  // 智能配对
  const pairMap = { '*': '*', '`': '`', '(': ')', '[': ']', '{': '}', '"': '"', "'": "'" };
  editBody.addEventListener('input', (e) => {
    if (e.inputType !== 'insertText') return;
    const char = e.data;
    if (!char || !pairMap[char]) return;
    const start = editBody.selectionStart;
    const end = editBody.selectionEnd;
    if (start !== end) return;
    const nextChar = editBody.value[start];
    if (pairMap[char] === nextChar) {
      editBody.setSelectionRange(start + 1, start + 1);
    } else {
      editBody.setRangeText(char + pairMap[char], start, start, 'end');
      editBody.setSelectionRange(start + 1, start + 1);
    }
  });

  // Enter 智能续行
  editBody.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    const start = editBody.selectionStart;
    const val = editBody.value;
    const lineStart = val.lastIndexOf('\n', start - 1) + 1;
    const line = val.substring(lineStart, start);

    const listMatch = line.match(/^(\s*)([-*+]|\d+\.)\s(.+)/);
    if (listMatch) {
      if (listMatch[3].trim() === '') {
        e.preventDefault();
        editBody.setRangeText('\n', start, start, 'end');
        editBody.dispatchEvent(new Event('input'));
        return;
      }
      e.preventDefault();
      const prefix = listMatch[1] + listMatch[2].replace(/\d+/, (n) => (parseInt(n) + 1) + '.') + ' ';
      editBody.setRangeText('\n' + prefix, start, start, 'end');
      editBody.dispatchEvent(new Event('input'));
      return;
    }

    if (line.match(/^>\s/)) {
      e.preventDefault();
      editBody.setRangeText('\n> ', start, start, 'end');
      editBody.dispatchEvent(new Event('input'));
    }
  });

  // ==================== 粘贴图片 ====================

  editBody.addEventListener('paste', function(e) {
    console.log('[paste] event fired', e);
    var cd = e.clipboardData || window.clipboardData;
    if (!cd) { console.log('[paste] no clipboardData'); return; }

    console.log('[paste] items:', cd.items ? cd.items.length : 0, 'files:', cd.files ? cd.files.length : 0);

    // 获取图片文件
    var imgFile = null;

    // 方法1: 从 items 获取
    if (cd.items && cd.items.length > 0) {
      for (var i = 0; i < cd.items.length; i++) {
        var item = cd.items[i];
        console.log('[paste] item[' + i + ']:', item.kind, item.type);
        if (item.kind === 'file' && item.type && item.type.startsWith('image/')) {
          try { imgFile = item.getAsFile(); } catch(ex) { console.log('[paste] getAsFile error:', ex); }
          if (imgFile) break;
        }
      }
    }

    // 方法2: 从 files 获取
    if (!imgFile && cd.files && cd.files.length > 0) {
      for (var i = 0; i < cd.files.length; i++) {
        console.log('[paste] file[' + i + ']:', cd.files[i].type, cd.files[i].size);
        if (cd.files[i].type && cd.files[i].type.startsWith('image/')) {
          imgFile = cd.files[i];
          break;
        }
      }
    }

    if (!imgFile) { console.log('[paste] no image found, letting browser handle'); return; }

    console.log('[paste] image found:', imgFile.type, imgFile.size);
    e.preventDefault();
    e.stopPropagation();

    var ext = (imgFile.type.split('/')[1] || 'png').replace('jpeg', 'jpg');
    var name = 'paste-' + Date.now() + '-' + Math.random().toString(36).substring(2, 8) + '.' + ext;

    // 插入文本占位，不提前请求最终图片地址，避免预览先缓存 404。
    var cursorPos = editBody.selectionStart;
    var placeholder = '\n[图片上传中: ' + name + ']\n';
    editBody.setRangeText(placeholder, cursorPos, cursorPos, 'end');
    editBody.dispatchEvent(new Event('input'));

    // 读取并上传
    var reader = new FileReader();
    reader.onload = function() {
      var dataUrl = reader.result || '';
      var base64 = String(dataUrl).split(',')[1] || '';
      console.log('[paste] base64 length:', base64.length);

      fetch('/api/posts', {
        method: 'POST',
        headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'upload-image', filename: name, content: base64 }),
      }).then(function(res) {
        console.log('[paste] upload response:', res.status);
        if (!res.ok) {
          return getErrorMessage(res, 'HTTP ' + res.status).then(function(message) {
            throw new Error(message);
          });
        }
        return res.json();
      }).then(function(result) {
        console.log('[paste] upload success:', result.path);
        var val = editBody.value;
        var idx = val.indexOf(placeholder);
        if (idx !== -1) {
          var imagePath = result.path + (result.path.indexOf('?') === -1 ? '?' : '&') + 'v=' + encodeURIComponent(result.sha || Date.now());
          var realMd = '\n![' + name + '](' + imagePath + ')\n';
          editBody.setRangeText(realMd, idx, idx + placeholder.length, 'end');
          editBody.dispatchEvent(new Event('input'));
        }
      }).catch(function(err) {
        console.error('[paste] upload failed:', err);
        alert('图片上传失败: ' + err.message);
        var val = editBody.value;
        var idx = val.indexOf(placeholder);
        if (idx !== -1) {
          editBody.setRangeText('', idx, idx + placeholder.length, 'end');
          editBody.dispatchEvent(new Event('input'));
        }
      });
    };
    reader.readAsDataURL(imgFile);
  });

  // ==================== 面板 & 登录 ====================

  document.getElementById('admin-toggle').addEventListener('click', () => {
    panel.classList.remove('translate-x-full');
    overlay.classList.remove('hidden');
    if (token) {
      loadPosts();
    } else {
      showView(loginView);
    }
  });

  document.getElementById('admin-close').addEventListener('click', closePanel);
  overlay.addEventListener('click', closePanel);

  function closePanel() {
    panel.classList.add('translate-x-full');
    overlay.classList.add('hidden');
  }

  document.getElementById('github-login').addEventListener('click', () => {
    const authWindow = window.open('/api/auth', 'github-oauth', 'width=600,height=700');
    window.addEventListener('message', (e) => {
      if (e.data?.token) {
        token = e.data.token;
        localStorage.setItem('gh_token', token);
        loadPosts();
      }
    });
  });

  // ==================== 文章列表 ====================

  async function loadPosts() {
    showLoading(true);
    try {
      const res = await fetch('/api/posts', {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) throw new Error('Failed to load');
      posts = await res.json();
      renderPostList();
      showView(listView);
    } catch (err) {
      localStorage.removeItem('gh_token');
      token = null;
      showView(loginView);
    }
    showLoading(false);
  }

  function renderPostList() {
    document.getElementById('post-count').textContent = `${posts.length} 篇文章`;
    const container = document.getElementById('posts-list');
    container.innerHTML = posts.map((p) => {
      const tags = Array.isArray(p.tags) ? p.tags : [];
      return `
      <div class="px-5 py-3 border-b border-border hover:bg-bg transition-colors cursor-pointer flex items-start gap-3" data-filename="${escapeHtml(p.filename)}">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2">
            <h4 class="text-sm font-medium truncate">${escapeHtml(p.title)}</h4>
            ${p.draft ? '<span class="px-1.5 py-0.5 text-[10px] bg-amber-100 text-amber-700 rounded">草稿</span>' : ''}
          </div>
          <div class="flex items-center gap-2 mt-1 text-xs text-text-secondary">
            <span>${escapeHtml(p.date)}</span>
            ${tags.length ? '<span>·</span><span>' + escapeHtml(tags.join(', ')) + '</span>' : ''}
          </div>
        </div>
        <button data-delete="${escapeHtml(p.filename)}" data-sha="${escapeHtml(p.sha)}" data-title="${escapeHtml(p.title)}" class="p-1.5 text-text-secondary hover:text-red-500 transition-colors flex-shrink-0" title="删除">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
            <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
          </svg>
        </button>
      </div>
    `;
    }).join('');

    container.querySelectorAll('[data-filename]').forEach((el) => {
      el.addEventListener('click', (e) => {
        if (e.target.closest('[data-delete]')) return;
        const post = posts.find((p) => p.filename === el.dataset.filename);
        if (post) openEditor(post);
      });
    });

    container.querySelectorAll('[data-delete]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const filename = btn.dataset.delete;
        const sha = btn.dataset.sha;
        const title = btn.dataset.title;
        if (!confirm(`确定删除「${title}」？`)) return;

        showLoading(true);
        try {
          const res = await fetch('/api/posts', {
            method: 'DELETE',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ filename, sha, title }),
          });
          if (!res.ok) throw new Error('Delete failed');
          await loadPosts();
        } catch (err) {
          alert('删除失败: ' + err.message);
        }
        showLoading(false);
      });
    });
  }

  // ==================== 编辑器 ====================

  document.getElementById('new-post-btn').addEventListener('click', () => openEditor(null));

  function openEditor(post) {
    currentPost = post;
    editorTitle.textContent = post ? '编辑文章' : '新建文章';
    document.getElementById('editor-delete').classList.toggle('hidden', !post);

    document.getElementById('edit-title').value = post?.title || '';
    document.getElementById('edit-date').value = post?.date || new Date().toISOString().split('T')[0];
    document.getElementById('edit-tags').value = post?.tags?.join(', ') || '';
    document.getElementById('edit-desc').value = post?.description || '';
    document.getElementById('edit-draft').checked = post?.draft || false;
    document.getElementById('edit-body').value = post?.body || '';

    resetTabLayout();
    showView(editorView);
    closePanel();
    document.body.style.overflow = 'hidden';
    setTimeout(function() { editBody.focus(); }, 100);
  }

  document.getElementById('editor-back').addEventListener('click', () => {
    document.body.style.overflow = '';
    resetTabLayout();
    editorView.classList.add('hidden');
    editorView.classList.remove('flex');
    panel.classList.remove('translate-x-full');
    overlay.classList.remove('hidden');
    renderPostList();
    showView(listView);
  });

  // 保存（发布）
  document.getElementById('editor-save').addEventListener('click', async () => {
    const title = document.getElementById('edit-title').value.trim();
    if (!title) { alert('请输入标题'); return; }
    if (!token) { alert('请先登录 GitHub'); return; }

    const date = document.getElementById('edit-date').value;
    const tags = document.getElementById('edit-tags').value.split(',').map((t) => t.trim()).filter(Boolean);
    const description = document.getElementById('edit-desc').value.trim();
    const draft = document.getElementById('edit-draft').checked;
    const body = document.getElementById('edit-body').value;

    const saveBtn = document.getElementById('editor-save');
    saveBtn.textContent = '发布中...';
    saveBtn.disabled = true;

    try {
      if (currentPost) {
        const res = await fetch('/api/posts', {
          method: 'PUT',
          headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...currentPost, title, date, tags, description, draft, body }),
        });
        if (!res.ok) throw new Error('Save failed');
        const data = await res.json();
        currentPost.sha = data.sha;
      } else {
        const slug = makeSlug(title);
        const filename = `${slug}.mdx`;
        const res = await fetch('/api/posts', {
          method: 'POST',
          headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ filename, title, date, tags, description, draft, body }),
        });
        if (!res.ok) throw new Error('Save failed');
        const data = await res.json();
        currentPost = { filename, sha: data.sha };
        editorTitle.textContent = '编辑文章';
        document.getElementById('editor-delete').classList.remove('hidden');
      }
      saveBtn.textContent = '已发布 ✓';
      setTimeout(() => { saveBtn.textContent = '发布'; }, 1500);
    } catch (err) {
      alert('发布失败: ' + err.message);
    }
    saveBtn.textContent = '发布';
    saveBtn.disabled = false;
  });

  // 删除文章
  document.getElementById('editor-delete').addEventListener('click', async () => {
    if (!currentPost) return;
    if (!confirm(`确定删除「${currentPost.title}」？`)) return;

    showLoading(true);
    try {
      const res = await fetch('/api/posts', {
        method: 'DELETE',
        headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ filename: currentPost.filename, sha: currentPost.sha, title: currentPost.title }),
      });
      if (!res.ok) throw new Error('Delete failed');
      document.body.style.overflow = '';
      editorView.classList.add('hidden');
      editorView.classList.remove('flex');
      panel.classList.remove('translate-x-full');
      overlay.classList.remove('hidden');
      await loadPosts();
    } catch (err) {
      alert('删除失败: ' + err.message);
    }
    showLoading(false);
  });

  // ==================== 上传文件 ====================

  let pendingContent = '';
  const uploadModal = document.getElementById('upload-modal');

  document.getElementById('upload-modal-close').addEventListener('click', closeUploadModal);
  document.getElementById('upload-cancel').addEventListener('click', closeUploadModal);

  function closeUploadModal() {
    uploadModal.classList.add('hidden');
    uploadModal.classList.remove('flex');
    pendingContent = '';
    document.getElementById('file-upload').value = '';
  }

  document.getElementById('file-upload').addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    if (!token) { alert('请先登录 GitHub'); return; }

    pendingContent = await file.text();

    let title = file.name.replace(/\.(md|mdx)$/, '');
    let date = new Date().toISOString().split('T')[0];
    let tags = '';
    let description = '';
    let draft = false;

    const fmMatch = pendingContent.match(/^---\n([\s\S]*?)\n---\n/);
    if (fmMatch) {
      const fm = fmMatch[1];
      const t = fm.match(/title:\s*"?([^"\n]+)"?/);
      const d = fm.match(/date:\s*"?([^"\n]+)"?/);
      const tg = fm.match(/tags:\s*\[([^\]]*)\]/);
      const desc = fm.match(/description:\s*"?([^"\n]+)"?/);
      const dr = fm.match(/draft:\s*(true|false)/);
      if (t) title = t[1].trim();
      if (d) date = d[1].trim();
      if (tg) tags = tg[1].split(',').map(s => s.trim().replace(/["']/g, '')).filter(Boolean).join(', ');
      if (desc) description = desc[1].trim();
      if (dr) draft = dr[1] === 'true';
    }

    const slug = makeSlug(title);
    document.getElementById('upload-filename').value = `${slug}.mdx`;
    document.getElementById('upload-title').value = title;
    document.getElementById('upload-date').value = date;
    document.getElementById('upload-tags').value = tags;
    document.getElementById('upload-desc').value = description;
    document.getElementById('upload-draft').checked = draft;

    uploadModal.classList.remove('hidden');
    uploadModal.classList.add('flex');
    document.getElementById('upload-title').focus();
  });

  document.getElementById('upload-title').addEventListener('input', (e) => {
    const slug = makeSlug(e.target.value);
    if (slug) document.getElementById('upload-filename').value = `${slug}.mdx`;
  });

  document.getElementById('upload-confirm').addEventListener('click', async () => {
    const title = document.getElementById('upload-title').value.trim();
    if (!title) { alert('请输入标题'); return; }
    if (!pendingContent) { alert('文件内容为空'); return; }

    const filename = document.getElementById('upload-filename').value.trim() || `${makeSlug(title)}.mdx`;
    const date = document.getElementById('upload-date').value;
    const tags = document.getElementById('upload-tags').value.split(',').map(t => t.trim()).filter(Boolean);
    const description = document.getElementById('upload-desc').value.trim();
    const draft = document.getElementById('upload-draft').checked;

    let body = pendingContent;
    const fmMatch = body.match(/^---\n[\s\S]*?\n---\n([\s\S]*)$/);
    if (fmMatch) body = fmMatch[1];

    const btn = document.getElementById('upload-confirm');
    btn.textContent = '发布中...';
    btn.disabled = true;

    try {
      const res = await fetch('/api/posts', {
        method: 'POST',
        headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ filename, title, date, tags, description, draft, body }),
      });
      if (!res.ok) throw new Error('Upload failed');
      closeUploadModal();
      await loadPosts();
    } catch (err) {
      alert('发布失败: ' + err.message);
    }
    btn.textContent = '发布';
    btn.disabled = false;
  });
})();
</script>

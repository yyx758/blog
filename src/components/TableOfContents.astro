---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="hidden xl:block fixed right-8 top-24 w-56 rounded-lg border border-border bg-bg-card/75 p-4 shadow-sm backdrop-blur">
    <p class="text-xs font-semibold text-text-secondary uppercase tracking-[0.16em] mb-3">目录</p>
    <ul class="space-y-1">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block rounded-md py-1 text-sm text-text-secondary hover:text-primary transition-colors leading-snug',
              { 'pl-0': heading.depth === 2 },
              { 'pl-3': heading.depth === 3 },
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

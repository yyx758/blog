---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="hidden xl:flex fixed right-8 top-24 max-h-[calc(100vh-8rem)] w-56 flex-col rounded-lg border border-border bg-bg-card/75 p-4 shadow-sm backdrop-blur">
    <p class="text-xs font-semibold text-text-secondary uppercase tracking-[0.16em] mb-3">目录</p>
    <ul class="min-h-0 space-y-1 overflow-y-auto pr-1 [scrollbar-width:thin]">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block rounded-md py-1 text-sm text-text-secondary hover:text-primary transition-colors leading-snug break-words',
              { 'pl-0': heading.depth === 2 },
              { 'pl-3': heading.depth === 3 },
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

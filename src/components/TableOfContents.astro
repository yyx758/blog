---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="hidden xl:block fixed right-8 top-1/2 -translate-y-1/2 w-56">
    <p class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-3">目录</p>
    <ul class="space-y-1.5">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block text-sm text-text-secondary hover:text-primary transition-colors leading-snug',
              { 'pl-0': heading.depth === 2 },
              { 'pl-3': heading.depth === 3 },
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

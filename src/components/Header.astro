---
const navLinks = [
  { href: '/blog/', label: '首页' },
  { href: '/blog/posts', label: '文章' },
  { href: '/blog/tags', label: '标签' },
  { href: '/blog/about', label: '关于' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border">
  <nav class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/blog/" class="text-lg font-bold tracking-tight hover:text-primary transition-colors">
      我的博客
    </a>
    <ul class="flex gap-6 text-sm">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'transition-colors hover:text-primary',
              { 'text-primary font-medium': currentPath === href || (href !== '/' && currentPath.startsWith(href)) },
              { 'text-text-secondary': !(currentPath === href || (href !== '/' && currentPath.startsWith(href))) },
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

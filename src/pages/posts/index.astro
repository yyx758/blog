---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const getReadTime = (body = '') => Math.max(1, Math.ceil(body.split(/\s+/).filter(Boolean).length / 200));
---

<BaseLayout title="文章">
  <header class="mb-8 border-b border-border pb-6">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary">Archive</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight">全部文章</h1>
    <p class="mt-3 text-sm leading-6 text-text-secondary">
      共 {posts.length} 篇公开文章，按发布时间倒序排列。
    </p>
  </header>

  {posts.length === 0 ? (
    <div class="rounded-lg border border-dashed border-border bg-bg-card/60 p-6 text-sm text-text-secondary">还没有文章。</div>
  ) : (
    <div class="grid gap-3">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          tags={post.data.tags}
          slug={post.id}
          readTime={getReadTime(post.body)}
        />
      ))}
    </div>
  )}
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const dateStr = post.data.date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const wordCount = post.body?.split(/\s+/).length ?? 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <TableOfContents headings={headings} />

  <article>
    <header class="mb-8 border-b border-border pb-7">
      <a href="/posts" class="mb-5 inline-flex text-sm font-medium text-primary hover:underline">&larr; 全部文章</a>
      <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl">{post.data.title}</h1>
      <div class="mt-4 flex items-center gap-3 text-sm text-text-secondary flex-wrap">
        <time datetime={post.data.date.toISOString()}>{dateStr}</time>
        <span>·</span>
        <span>{readTime} 分钟阅读</span>
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {post.data.tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-full border border-border bg-bg-muted px-2.5 py-1 text-xs text-text-secondary transition-colors hover:border-primary/35 hover:text-primary"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </div>
      {post.data.description && (
        <p class="mt-4 text-base leading-7 text-text-secondary">{post.data.description}</p>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>

  <div class="mt-12 pt-6 border-t border-border">
    <a href="/posts" class="inline-flex rounded-md border border-border bg-bg-card px-3 py-2 text-sm font-medium text-text shadow-sm transition-all hover:-translate-y-0.5 hover:border-border-strong">&larr; 返回全部文章</a>
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const tagCount = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签">
  <header class="mb-8 border-b border-border pb-6">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary">Index</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight">全部标签</h1>
    <p class="mt-3 text-sm leading-6 text-text-secondary">
      用标签把学习笔记和项目复盘串起来，方便按主题回看。
    </p>
  </header>

  {tags.length === 0 ? (
    <div class="rounded-lg border border-dashed border-border bg-bg-card/60 p-6 text-sm text-text-secondary">还没有标签。</div>
  ) : (
    <div class="grid gap-3 sm:grid-cols-2">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}`}
          class="group flex items-center justify-between rounded-lg border border-border bg-bg-card/75 px-4 py-3 text-sm shadow-sm transition-all hover:-translate-y-0.5 hover:border-border-strong hover:shadow-md"
        >
          <span class="font-medium group-hover:text-primary">{tag}</span>
          <span class="font-mono text-xs text-text-secondary">{count}</span>
        </a>
      ))}
    </div>
  )}
</BaseLayout>

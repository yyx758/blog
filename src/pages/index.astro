---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const tagCount = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
  }
}
const popularTags = [...tagCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

const lastUpdated = allPosts[0]?.data.date;
const lastUpdatedText = lastUpdated
  ? lastUpdated.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
  : '准备中';

const getReadTime = (body = '') => Math.max(1, Math.ceil(body.split(/\s+/).filter(Boolean).length / 200));

const focusAreas = [
  {
    name: 'Spring AI',
    desc: '记录框架能力、工程接入方式和真实项目中的取舍。',
    meta: 'AI 应用工程',
  },
  {
    name: '大模型原理',
    desc: '用可复盘的笔记拆解 Transformer、RAG、Agent 等核心概念。',
    meta: 'LLM 基础',
  },
  {
    name: '后端工程',
    desc: '关注服务设计、接口治理、部署链路和长期可维护性。',
    meta: 'Java / 架构',
  },
];
---

<BaseLayout title="首页" wide>
  <section class="grid items-center gap-8 py-6 sm:py-10 lg:grid-cols-[0.95fr_1.05fr] lg:gap-14">
    <div class="min-w-0">
      <div class="mb-5 flex flex-wrap gap-2">
        <span class="rounded-full border border-border bg-bg-card px-3 py-1 text-xs font-medium text-text-secondary shadow-sm">Java / Spring AI</span>
        <span class="rounded-full border border-border bg-bg-card px-3 py-1 text-xs font-medium text-text-secondary shadow-sm">LLM 学习记录</span>
      </div>
      <h1 class="max-w-2xl text-4xl font-bold leading-tight tracking-tight text-text sm:text-5xl">
        构建自己的技术体系，<span class="text-primary">从一篇可复盘的笔记开始</span>
      </h1>
      <p class="mt-5 max-w-xl text-base leading-8 text-text-secondary sm:text-lg">
        记录学习、分享技术、复盘项目，在持续实践中构建自己的技术体系。
      </p>

      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href="/posts"
          class="inline-flex h-10 items-center rounded-md bg-primary px-4 text-sm font-medium text-white shadow-sm transition-all hover:-translate-y-0.5 hover:bg-primary-light hover:shadow-md"
        >
          开始阅读
        </a>
        <a
          href="/tags"
          class="inline-flex h-10 items-center rounded-md border border-border bg-bg-card px-4 text-sm font-medium text-text shadow-sm transition-all hover:-translate-y-0.5 hover:border-border-strong"
        >
          浏览主题
        </a>
      </div>

      <dl class="mt-8 grid max-w-md grid-cols-3 gap-3">
        <div>
          <dt class="text-xs text-text-secondary">文章</dt>
          <dd class="mt-1 font-mono text-xl font-semibold">{allPosts.length}</dd>
        </div>
        <div>
          <dt class="text-xs text-text-secondary">标签</dt>
          <dd class="mt-1 font-mono text-xl font-semibold">{tagCount.size}</dd>
        </div>
        <div>
          <dt class="text-xs text-text-secondary">更新</dt>
          <dd class="mt-1 font-mono text-sm font-semibold leading-7">{lastUpdatedText}</dd>
        </div>
      </dl>
    </div>

    <div class="relative overflow-hidden rounded-xl border border-border bg-bg-card shadow-sm">
      <img
        src="/images/hero-developer-desk-light.jpg"
        alt="日间开发者桌面，包含笔记本电脑、键盘、笔记本和技术书籍"
        class="aspect-[16/9] w-full object-cover dark:hidden"
        loading="eager"
        width="1680"
        height="945"
      />
      <img
        src="/images/hero-developer-desk-dark.jpg"
        alt="夜间开发者桌面，包含笔记本电脑、键盘、笔记本和技术书籍"
        class="hidden aspect-[16/9] w-full object-cover dark:block"
        loading="eager"
        width="1680"
        height="945"
      />
    </div>
  </section>

  <section class="border-t border-border py-8 sm:py-10">
    <div class="mb-5 flex items-end justify-between gap-4">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary">Focus</p>
        <h2 class="mt-2 text-xl font-semibold tracking-tight">学习方向</h2>
      </div>
    </div>
    <div class="grid gap-3 md:grid-cols-3">
      {focusAreas.map((item) => (
        <section class="rounded-lg border border-border bg-bg-card/75 p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:border-border-strong hover:shadow-md">
          <p class="font-mono text-xs text-primary">{item.meta}</p>
          <h3 class="mt-3 text-base font-semibold">{item.name}</h3>
          <p class="mt-2 text-sm leading-6 text-text-secondary">{item.desc}</p>
        </section>
      ))}
    </div>
  </section>

  <section class="border-t border-border py-8 sm:py-10">
    <div class="mb-5 flex items-center justify-between gap-4">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary">Recent</p>
        <h2 class="mt-2 text-xl font-semibold tracking-tight">最近文章</h2>
      </div>
      <a href="/posts" class="text-sm font-medium text-primary hover:underline">查看全部 -&gt;</a>
    </div>

    <div class="grid gap-3">
      {recentPosts.length === 0 ? (
        <div class="rounded-lg border border-dashed border-border bg-bg-card/60 p-6 text-sm text-text-secondary">
          还没有文章。发布第一篇后，这里会自动展示最近更新。
        </div>
      ) : (
        recentPosts.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            tags={post.data.tags}
            slug={post.id}
            readTime={getReadTime(post.body)}
          />
        ))
      )}
    </div>
  </section>

  <!-- Tags -->
  {popularTags.length > 0 && (
    <section class="border-t border-border py-8 sm:py-10">
      <div class="flex items-center justify-between mb-6">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary">Tags</p>
          <h2 class="mt-2 text-xl font-semibold tracking-tight">标签</h2>
        </div>
        <a href="/tags" class="text-sm font-medium text-primary hover:underline">全部标签 -&gt;</a>
      </div>
      <div class="flex flex-wrap gap-2.5">
        {popularTags.map(([tag, count]) => (
          <a
            href={`/tags/${tag}`}
            class="rounded-full border border-border bg-bg-card px-3.5 py-2 text-sm text-text-secondary shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/35 hover:text-text"
          >
            {tag}
            <span class="ml-1 opacity-50">({count})</span>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

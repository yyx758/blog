---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <p class="text-8xl font-bold text-border mb-4">404</p>
    <h1 class="text-2xl font-bold mb-3">页面未找到</h1>
    <p class="text-text-secondary mb-8">你访问的页面不存在，或者已经被移除了。</p>
    <a
      href="/"
      class="inline-flex items-center px-6 py-2.5 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary-light transition-colors"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
